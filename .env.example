# ============================================================
# RAILWAY FULLSTACK DEPLOYMENT TEMPLATE
# ============================================================
# Copy this file to:
#   .env.development   (local dev)
#   .env.production    (Railway prod)
# ============================================================

# =========================
# FRONTEND (Vite build-time)
# =========================

# Legacy single API URL (development with proxy)
VITE_API_URL=/api

# Railway: Separate API URLs for Terminal and Journal services
# In development, both point to the same backend (Vite proxy)
# In production (Railway), these are separate service URLs
VITE_TERMINAL_API_URL=/api
VITE_JOURNAL_API_URL=/api

# Feature Flags
VITE_ENABLE_DEV_NAV=true
VITE_ENABLE_SW_POLLING=false
VITE_RESEARCH_EMBED_TERMINAL=false
VITE_ENABLE_AUTH=false

# Public Web Push Key (safe to expose)
VITE_VAPID_PUBLIC_KEY=

# Optional: frontend audit mode
VITE_AUDIT_MODE=false


# =========================
# SERVER RUNTIME (Railway)
# =========================

NODE_ENV=development
LOG_LEVEL=info

# Service Mode: 'full' | 'terminal' | 'journal'
# - 'full': All routes enabled (development, monolith)
# - 'terminal': Only trading routes (/quote, /swap, /discover)
# - 'journal': Only journal/LLM routes (/journal, /reasoning, /llm, etc.)
SERVICE_MODE=full

# Port (Railway injects $PORT, but we provide default for local dev)
PORT=3000
BACKEND_PORT=3000


# =========================
# DATABASE (Railway Postgres)
# =========================

# Local (Dev) - SQLite
DATABASE_URL=sqlite:./.data/tradeapp.sqlite

# Production (Railway) - PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/dbname


# =========================
# CACHE (Railway Redis)
# =========================

# Redis URL for quote caching, sessions, rate limiting
# Optional - if not set, uses in-memory fallback
REDIS_URL=

# Legacy Vercel KV (optional fallback)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=


# =========================
# LLM (Journal Service)
# =========================

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_JOURNAL=gpt-4o-mini
OPENAI_MODEL_INSIGHTS=gpt-4o-mini
OPENAI_MODEL_CHARTS=gpt-4o-mini
OPENAI_ORG_ID=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_REASONING=deepseek-reasoner
DEEPSEEK_MODEL_ROUTER=deepseek-reasoner
DEEPSEEK_MODEL_ANSWER=deepseek-chat

GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL_PULSE=grok-beta

# Legacy fallback model name
OPUS_MODEL=gpt-4o-mini

# LLM Router Settings
LLM_TIMEOUT_MS=20000
LLM_MAX_RETRIES=2
LLM_ROUTER_ENABLED=true
LLM_ROUTER_DEBUG=false
LLM_BUDGET_DEFAULT=low
LLM_TIER_DEFAULT=free
LLM_FALLBACK_PROVIDER=


# =========================
# TERMINAL (Terminal Service)
# =========================

# Jupiter API
JUPITER_BASE_URL=https://quote-api.jup.ag/v6
JUPITER_PLATFORM_FEE_ACCOUNT=
TERMINAL_SWAP_REQUIRE_AUTH=false

# Quote Cache Settings
QUOTE_CACHE_TTL_SECONDS=5
QUOTE_STALE_TTL_MS=25000

# Solana RPC (Helius)
HELIUS_API_KEY=
HELIUS_RPC_URL=
HELIUS_DAS_RPC_URL=
HELIUS_TIMEOUT_MS=10000
HELIUS_ENHANCED_MAX_PAGES=
HELIUS_ENHANCED_LIMIT=

# Circuit Breaker / RPC Settings
RPC_KEEP_ALIVE_MS=30000
RPC_TIMEOUT_MS=10000
RPC_FALLBACK_ENABLED=true
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_MS=30000
RATE_LIMIT_QUOTES_PER_MIN=60

# Onchain Gating
ONCHAIN_TUNING_PROFILE=default


# =========================
# CRYPTO DATA PROVIDERS
# =========================

DEXPAPRIKA_API_KEY=
MORALIS_API_KEY=


# =========================
# WEB PUSH (SERVER SIGNS)
# =========================

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com


# =========================
# SECURITY
# =========================

JWT_SECRET=dev-secret-change-in-production
SESSION_SECRET=
CRON_SECRET=


# =========================
# MONITORING
# =========================

WATCHER_INTERVAL_MS=5000
EVALUATION_BATCH_SIZE=200
EVENT_RETENTION_DAYS=30
SSE_HEARTBEAT_MS=20000

# Sentry (Optional)
# VITE_SENTRY_DSN=
