# Backend (canonical, always-on) — example env
#
# Copy to backend/.env and adjust as needed.

NODE_ENV=development
BACKEND_PORT=3000
API_BASE_PATH=/api
LOG_LEVEL=info

# SQLite (default)
DATABASE_URL=sqlite:./.data/tradeapp.sqlite

# Auth
# Production requires:
# - JWT_SECRET with >= 32 chars and not "dev-secret"
# - BACKEND_CORS_ORIGINS with explicit allowlist
JWT_SECRET=dev-secret
BACKEND_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Solana Onchain (required by backend/src/config/env.ts)
HELIUS_API_KEY=your-helius-api-key
# Optional overrides (defaults apply if unset)
# HELIUS_RPC_URL=https://rpc.helius.xyz/?api-key=...
# HELIUS_DAS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=...
# HELIUS_TIMEOUT_MS=1200

# Optional providers (only required if the feature is used)
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GROK_API_KEY=
# MORALIS_API_KEY=

# Optional KV persistence
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
